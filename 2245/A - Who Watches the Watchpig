#include <bits/stdc++.h>
using namespace std;
#define int long long int
#define all(x) x.begin(), x.end()
 
void solve() 
{
    int n, k;
    string s;
    cin >> n >> k >> s;
    if (2 * k > n) {
        cout << "-1
";
    } 
    else {
        int ans = 0;
        for (int i = 0; i < k; ++i) ans += (s[i] == 'L') + (s[n - 1 - i] == 'R');
        cout << ans << "
";
    }
}
int32_t main() {
    ios_base::sync_with_stdio(0); cin.tie(0);
    int t = 1; cin >> t;
    while (t--) solve();
    return 0;
}